# Anthropic Claude API
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://journi.maoratec.com

# Shared secret between Next.js and this service (generate with: openssl rand -hex 32)
# Must match BACKEND_SECRET_TOKEN in the Next.js .env.local
BACKEND_SECRET_TOKEN=
