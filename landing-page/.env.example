# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google Sheets Waitlist ───────────────────────────────────────────────────
# Step 1: Create a Google Service Account at https://console.cloud.google.com/
# Step 2: Enable Google Sheets API, create a JSON key
# Step 3: Paste the entire JSON as one line below
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Step 4: Share your Google Sheet with the service account email (Editor)
# Step 5: Copy the Sheet ID from the URL: /spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# ─── FastAPI (AI Service — Phase 2) ──────────────────────────────────────────
FASTAPI_URL=http://localhost:8000
